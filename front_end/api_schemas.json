        "resolution": ["512px", "1K", "2K", "4K"],
        "model": ["gemini-3.1-flash-image-preview"],
        "thinking_level": ["minimal", "high"],
        "include_thoughts": [false, true]
      },
      "request": {
        "method": "SDK",
        "endpoint": "client.models.generate_content",
        "sdk_call": {
          "args": [],
          "kwargs": {
            "model": "{{model}}",
            "contents": [
              "{{prompt}}",
              "{{reference_images}}"
            ],
            "config": {
              "$call": "types.GenerateContentConfig",
              "$args": [],
              "$kwargs": {
                "response_modalities": [
                  "{{config_response_modalities_0}}"
                ],
                "image_config": {
                  "$call": "types.ImageConfig",
                  "$args": [],
                  "$kwargs": {
                    "aspect_ratio": "{{aspect_ratio}}",
                    "image_size": "{{image_size}}"
                  }
                },
                "thinking_config": {
                  "$call": "types.ThinkingConfig",
                  "$args": [],
                  "$kwargs": {
                    "thinking_level": "{{thinking_level}}",
                    "include_thoughts": "{{include_thoughts}}"
                  }
                }
              }
            }
          }
        }
      }
    },
    "VEO": {
      "provider": "Gemini",
      "service": "VEO",
      "import_modules": [
        "from google import genai",
        "from google.genai import types"
      ],
      "possible_parameters": {
        "aspect_ratio": ["9:16", "16:9"],
        "durationSeconds": ["4", "6", "8"],
        "personGeneration": ["allow_all", "allow_adult", "dont_allow"],
        "resolution": ["720p", "1080p", "4K"],
        "model": ["veo-3.0-generate", "veo-3.0-fast-generate", "veo-3.1-generate-preview", "veo-3.1-generate", "veo-3.1-fast-generate-preview", "veo-3.1-fast-generate"]
      },
      "request": {
        "method": "SDK",
        "endpoint": "client.models.generate_videos",
        "sdk_call": {
          "args": [],
          "kwargs": {
            "model": "{{model}}",
            "prompt": "{{prompt}}",
            "image": "{{first_image}}",
            "config": {
              "$call": "types.GenerateVideosConfig",
              "$args": [],
              "$kwargs": {
                "aspectRatio": "{{aspect_ratio}}",
                "resolution": "{{config_resolution}}",
                "durationSeconds": "{{durationSeconds}}",
                "personGeneration": "{{personGeneration}}",
                "reference_images": "{{reference_images}}",
                "last_frame": "{{last_image}}"
              }
            }
          }
        }
      }
    },
    "Imagen": {
      "provider": "Gemini",
      "service": "Imagen",
      "import_modules": [
        "from google import genai",
        "from google.genai import types"
      ],
      "possible_parameters": {
        "aspect_ratio": ["1:1", "3:4", "4:3", "9:16", "16:9"],
        "resolution": ["1K", "2K"],
        "model": ["imagen-4.0-generate-001", "imagen-4.0-ultra-generate-001", "imagen-4.0-fast-generate-001"]
      },
      "request_exclusions": [
        {
          "when": {"path": "model", "equals": "imagen-4.0-fast-generate-001"},
          "remove": ["config.image_size"]
        }
      ],
      "request": {
        "method": "SDK",
        "endpoint": "client.models.generate_images",
        "sdk_call": {
          "args": [],
          "kwargs": {
            "model": "{{model}}",
            "prompt": "{{prompt}}",
            "config": {
              "$call": "types.GenerateImagesConfig",
              "$args": [],
              "$kwargs": {
                "number_of_images": "{{batch}}",
                "aspect_ratio": "{{aspect_ratio}}",
                "image_size": "{{resolution}}"
              }
            }
          }
        }
      }
    }
  },
