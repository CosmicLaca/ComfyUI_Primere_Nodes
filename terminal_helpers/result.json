              "image_urls": "{{reference_image}}",
              "video_urls": "{{video_urls}}",
              "audio_urls": "{{audio_urls}}",
              "resolution": "{{resolution}}",
              "seed": "{{seed}}",
              "duration": "{{duration}}",
              "aspect_ratio": "{{aspect_ratio}}",
              "with_logs": "{{with_logs}}"
